<?xml version="1.0" encoding="UTF-8"?>
<!--
  SYNTHETIC FIXTURE - contains no real location data.

  Hand-authored from the Arc Timeline GPX *schema* only (element structure,
  attribute names, field formats). Every coordinate is a made-up point on a
  tiny grid near 0,0 (Null Island) and every timestamp is a fake value in
  ISO week 2000-W01. Nothing here is shifted, offset, simplified, or in any
  other way derived from real coordinates, routes, or movement patterns.

  Structure mirrors Arc Timeline exports:
    gpx > trk > (name, type, trkseg > trkpt[lat,lon] > (ele, time))
    gpx > wpt[lat,lon] > (time, name)        (Arc exports visits as waypoints)

  Deliberate edge cases for parser/cleaning tests:
    - "stationary" track: tight cluster of points
    - "bogus" track: invalid category that should be hidden/ignored by default
    - empty trkseg (occurs in real Arc exports)
    - track with two trksegs (legal GPX, parser must not assume one)
    - consecutive duplicate points (car track)
    - impossible-speed teleport spike (metro track, jumps to lat 0.5 and back)
    - out-of-range coordinate lat=95 (cycling track)
    - trkpt with no ele/time children (hovercraft track)
    - unknown category "hovercraft" (tests unknown-type handling)
-->
<gpx version="1.1" xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" creator="Arc Timeline">
	<trk>
